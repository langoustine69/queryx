# === Queryx Environment Variables ===

# --- Payments (x402 / Base Mainnet) ---
# Your USDC receivable address on Base for x402 payments
PAYMENTS_RECEIVABLE_ADDRESS=0xYourBaseAddress

# x402 facilitator URL (Daydreams default)
FACILITATOR_URL=https://facilitator.daydreams.systems

# Network for x402 payments
NETWORK=base

# --- Search ---
# Brave Search API key (https://brave.com/search/api/)
BRAVE_API_KEY=BSA-xxxxxxxxxxxx

# --- AI Synthesis ---
# OpenAI API key for GPT-4o-mini synthesis
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# --- Server ---
# Port to listen on (Railway sets this automatically)
PORT=3000

# --- Cache ---
# TTL for in-memory search cache (seconds)
CACHE_TTL_SECONDS=300
